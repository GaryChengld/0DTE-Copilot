// Learn more about Prisma schema: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model MarketSnapshot {
  id         Int      @id
  ticker     String
  timestamp  DateTime
  marketData Json
}

model AiAdvice {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  source    String   // "job" | "user"
  prompt    String?  // user message; null for job-triggered entries
  response  String   // AI response in markdown
  provider  String   // "gemini" | "openai" | "claude"
}

model TradeLog {
  id          Int      @id @default(autoincrement())
  timestamp   DateTime @default(now())
  action      String
  description String
  pnl         Float?
}
