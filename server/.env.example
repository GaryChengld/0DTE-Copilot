DATABASE_URL=file:./dev.db
PORT=3001

# Prompt file name (relative to src/prompts/, default: strategicPrompt.md)
PROMPT_FILE=strategicPrompt.md

# LLM Provider: gemini | openai | claude (default: gemini)
LLM_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-6

# Auto-restart AI session after this many messages (default: 20)
SESSION_SUMMARY_INTERVAL=20
